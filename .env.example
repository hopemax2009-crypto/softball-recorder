# Firebase Realtime Database（管理者一次性設定）
# 建立專案：https://console.firebase.google.com
# 啟用 Realtime Database（不需 Firebase Authentication）
#
# 安全規則範例：
# {
#   "rules": {
#     "accounts": {
#       ".read": true,
#       "$username": {
#         ".write": true
#       }
#     },
#     "accountDirectory": {
#       ".read": true,
#       ".write": true
#     },
#     "userData": {
#       "$userId": {
#         ".read": true,
#         ".write": true
#       }
#     },
#     "rooms": {
#       "$roomId": {
#         ".read": true,
#         ".write": true
#       }
#     },
#     "publicStats": {
#       "$teamCode": {
#         ".read": true,
#         ".write": true
#       }
#     },
#     "publicGameReports": {
#       "$reportKey": {
#         ".read": true,
#         ".write": true
#       }
#     }
#   }
# }
#
# accounts：
#   - 父節點 ".read": true 可一次列出全部帳號
#   - "$username".write: true 才能改密／管理者重設
# accountDirectory：帳號索引（不含密碼）；用於「載入所有帳號」備援路徑
# 重要：請在 Console 左上選對 Realtime Database 實例
#   本專案 DATABASE_URL 是 asia-southeast1，規則要改「那個」庫，不是預設 us-central1
# userData：使用者比賽資料雲端存檔
# publicStats / publicGameReports：公開統計與單場戰報
# 管理者介面由 VITE_ADMIN_USERNAMES 控制（與 VITE_REGISTER_ALLOWED_USERNAMES 無關）

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your-project

# 註冊開關（預設 true；設為 false 代表完全關閉註冊）
VITE_ALLOW_REGISTER=true
# 允許註冊的帳號白名單（逗號分隔；留空代表任何帳號可註冊）
VITE_REGISTER_ALLOWED_USERNAMES=
# 管理者帳號清單（逗號分隔；可查看所有帳號的密碼雜湊）
VITE_ADMIN_USERNAMES=
